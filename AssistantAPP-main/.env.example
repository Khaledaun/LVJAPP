# LVJ Case Assistant — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# See CLAUDE.md §Phase 6 for the authoritative list.
# Non-production defaults are safe to leave blank; production requires all keys.

# === Database ===
DATABASE_URL="postgresql://username:password@127.0.0.1:5432/database_name"

# === NextAuth ===
NEXTAUTH_SECRET="your-super-secret-key-at-least-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# === Development mode flags (set to 1 to enable) ===
SKIP_AUTH=0          # 1 = bypass authentication for demos
SKIP_DB=0            # 1 = skip DB writes (audit/notify become no-ops)

# === Feature flags ===
ENABLE_STATUS_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_TRAFFIC_LIGHT_STATUS=true

# === Multi-LLM AI Router ===
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=

# === Voice (ElevenLabs + Twilio) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_EN=
ELEVENLABS_MODEL=eleven_multilingual_v2

# === WhatsApp (Kaspo) ===
KASPO_API_KEY=
KASPO_INSTANCE_ID=
KASPO_WEBHOOK_SECRET=

# === Social (PostBridge) ===
POSTBRIDGE_API_KEY=
POSTBRIDGE_WORKSPACE_ID=

# === Webflow (D-019 marketing parallel track · AD#12) ===
WEBFLOW_API_TOKEN=                  # Data API bearer; populated for Sprint 13
WEBFLOW_SITE_ID=                    # Sprint 13 prereq
WEBFLOW_WEBHOOK_SECRET=             # HMAC-SHA256 secret for webhook ingress (C-009)

# === Storage (GCS) ===
GCS_BUCKET=                  # legacy — kept for backwards compat
GCS_AUDIO_BUCKET=lvj-voice-audio   # public read (Twilio <Play>)
GCS_VAULT_BUCKET=lvj-docs-vault    # private — encrypted documents
GCS_PUBLIC_BUCKET=lvj-docs-public

# === Security ===
DOCUMENT_ENCRYPTION_KEY=           # 32-byte AES-256-GCM key, hex-encoded (64 chars)

# === Payments (Stripe + IOLTA) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_IOLTA_ACCOUNT_ID=

# === Notifications ===
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@lvj.law
FIREBASE_PROJECT_ID=
FIREBASE_VAPID_KEY=

# === Caching (optional but recommended) ===
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# === Runtime ===
NODE_ENV=development
PORT=3000
