datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../.prisma/client"
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  role             Role      @default(CLIENT)
  password         String?
  officeId         String?
  office           Office?   @relation(fields: [officeId], references: [id])
  casesAsClient    Case[]    @relation("CaseClient")
  casesAsManager   Case[]    @relation("CaseManager")
  casesAsLawyer    Case[]    @relation("Lawyer")
  serviceTypes     ServiceType[] @relation("ServiceTypeCounsel")
  auditLogs        AuditLog[]
  notificationLogs NotificationLog[]
  voiceCallLogs    VoiceCallLog[]
}

model ServiceType {
  id              String   @id @default(cuid())
  title           String   @unique
  description     String?
  code            String?  @unique
  category        String?
  typicalTimeline String?
  baseFee         Float?
  governmentFee   Float?   @default(0)
  requiredForms   String[] @default([])
  counselPool     User[]   @relation("ServiceTypeCounsel")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cases           Case[]
}

model Case {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  title                String
  caseNumber           String    @unique
  totalFee             Int
  currency             String
  applicantName        String
  applicantEmail       String
  overallStatus        CaseStatus
  stage                String
  urgencyLevel         String
  completionPercentage Int
  clientId             String?
  client               User?     @relation("CaseClient", fields: [clientId], references: [id])
  caseManagerId        String?
  caseManager          User?     @relation("CaseManager", fields: [caseManagerId], references: [id])
  lawyerId             String?
  lawyer               User?     @relation("Lawyer", fields: [lawyerId], references: [id])
  serviceTypeId        String?
  serviceType          ServiceType? @relation(fields: [serviceTypeId], references: [id])
  officeId             String?
  office               Office?   @relation(fields: [officeId], references: [id])
  partnerId            String?
  partner              Partner?  @relation("PartnerCase", fields: [partnerId], references: [id])
  documents            Document[]
  payments             Payment[]
  timelineEvents       TimelineEvent[]
  internalMessages     Message[]
  externalPartners     ExternalPartner[]
  externalComms        ExternalCommunication[]
  outcome              CaseOutcome?
  auditLogs            AuditLog[]
  notificationLogs     NotificationLog[]
  voiceCallLogs        VoiceCallLog[]
}

// Multi-office support (Architecture Decision #10 — officeId on staff-facing models)
model Office {
  id        String   @id @default(cuid())
  name      String
  city      String
  country   String
  timezone  String
  region    String   // MENA | Americas | Europe
  flag      String?
  isHQ      Boolean  @default(false)
  cases     Case[]
  members   User[]
  createdAt DateTime @default(now())
}

// Partner network (distinct from existing per-case ExternalPartner)
model Partner {
  id             String      @id @default(cuid())
  name           String
  type           PartnerType
  contactEmail   String
  contactPhone   String?
  commissionPct  Float       @default(0)
  totalReferrals Int         @default(0)
  totalRevenue   Float       @default(0)
  referralCode   String      @unique @default(cuid())
  cases          Case[]      @relation("PartnerCase")
  leads          EligibilityLead[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// Outcome predictor data collection
model CaseOutcome {
  id                    String        @id @default(cuid())
  caseId                String        @unique
  case                  Case          @relation(fields: [caseId], references: [id])
  serviceCode           String
  officerLocation       String?
  filingDate            DateTime?
  adjudicationDate      DateTime?
  outcome               OutcomeResult
  rfeIssued             Boolean       @default(false)
  rfeResponseDays       Int?
  approvalOddsPredicted Float?
  approvalOddsActual    Float?
  createdAt             DateTime      @default(now())
}

// Eligibility quiz leads
model EligibilityLead {
  id           String     @id @default(cuid())
  email        String
  phone        String?
  name         String?
  answers      Json
  score        Float
  visaCategory String?
  status       LeadStatus @default(NEW)
  caseId       String?
  source       String?
  partnerId    String?
  partner      Partner?   @relation(fields: [partnerId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Multi-channel notification feed
model NotificationLog {
  id         String       @id @default(cuid())
  caseId     String?
  case       Case?        @relation(fields: [caseId], references: [id])
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  channel    NotifChannel
  subject    String?
  body       String       @db.Text
  status     NotifStatus  @default(QUEUED)
  externalId String?
  readAt     DateTime?
  createdAt  DateTime     @default(now())
}

// Voice call log (ElevenLabs + Twilio pipeline)
model VoiceCallLog {
  id          String   @id @default(cuid())
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  twilioSid   String?
  direction   String   // OUTBOUND | INBOUND
  status      String   // queued | ringing | in-progress | completed | failed
  duration    Int?
  audioGcsUrl String?
  transcript  String?  @db.Text
  locale      String   @default("en")
  createdAt   DateTime @default(now())
}

// Audit log (referenced by lib/audit.ts — previously missing from schema)
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  action    String
  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  diff      Json?
}

// ─────────────────────────────────────────────────────────────
// Agent Operating System (docs/AGENT_OS.md §4, §9, §10) — Phase 1
// All additive per Golden Rule #4.
// ─────────────────────────────────────────────────────────────

// Every agent invocation writes one row here.
model AutomationLog {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  agentId            String
  agentVersion       String
  correlationId      String
  triggerEvent       String
  caseId             String?
  leadId             String?
  startedAt          DateTime
  durationMs         Int
  status             AutomationStatus @default(OK)
  costUsd            Float    @default(0)
  tokensIn           Int      @default(0)
  tokensOut          Int      @default(0)
  llmCalls           Int      @default(0)
  promptVersion      String?
  modelPrimary       String?
  modelFallbackUsed  Boolean  @default(false)
  escalationEvent    String?
  errorClass         String?
  errorMessage       String?

  @@index([agentId, createdAt])
  @@index([correlationId])
  @@index([caseId])
}

enum AutomationStatus {
  OK
  ESCALATED
  HUMAN_BLOCKED
  CIRCUIT_BROKEN
  ERROR
}

// Drafts produced by any workflow agent before HITL / send.
model AgentDraft {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  agentId       String
  agentVersion  String
  correlationId String
  caseId        String?
  leadId        String?
  templateId    String
  channel       String    // email | whatsapp | portal | letter | internal
  subject       String?
  body          String    @db.Text
  variables     Json
  promptVersion String?
  modelUsed     String?
  adviceClass   String    @default("general_information")  // general_information | firm_process | attorney_approved_advice
  reviewState   DraftReviewState @default(DRAFT)
  guardrailReport Json?
  sentAt        DateTime?
  externalId    String?   // NotificationLog.externalId after send
  createdBy     String?

  @@index([caseId])
  @@index([leadId])
  @@index([reviewState])
  @@index([correlationId])
}

enum DraftReviewState {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT
}

// Pending / decided HITL approvals.
model HITLApproval {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  agentId       String
  gateId        String
  correlationId String
  caseId        String?
  leadId        String?
  draftId       String?    // optional link to AgentDraft
  payload       Json
  approverRole  String
  requestedAt   DateTime   @default(now())
  slaDueAt      DateTime
  status        HITLStatus @default(PENDING)
  decidedBy     String?
  decidedAt     DateTime?
  reason        String?    @db.Text
  diff          Json?

  @@index([status, slaDueAt])
  @@index([caseId])
  @@index([correlationId])
}

enum HITLStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// Typed deadlines owned by the Deadline agent.
model CaseDeadline {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  caseId      String
  kind        String         // e.g. "rfe_response", "biometrics", "interview", "filing_window"
  title       String
  dueAt       DateTime
  quietHoursTz String?       // IANA tz, used for reminder windowing
  remindersSent Json         @default("[]")  // array of { at, channel, status }
  status      CaseDeadlineStatus @default(UPCOMING)
  escalatedAt DateTime?
  notes       String?        @db.Text

  @@index([caseId])
  @@index([dueAt, status])
}

enum CaseDeadlineStatus {
  UPCOMING
  APPROACHING  // within reminder window
  DUE_SOON     // within 48h
  OVERDUE
  MISSED
  RESOLVED
  CANCELLED
}

model PartnerRole {
  id       String            @id @default(cuid())
  name     String            @unique
  partners ExternalPartner[]
}

model ExternalPartner {
  id     String    @id @default(cuid())
  name   String
  email  String?
  type   String
  case   Case      @relation(fields: [caseId], references: [id])
  caseId String
  role   PartnerRole @relation(fields: [roleId], references: [id])
  roleId String
}

model ExternalCommunication {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  direction Direction
  body      String    @db.Text
  sender    String
  case      Case      @relation(fields: [caseId], references: [id])
  caseId    String
}

model Document {
  id     String   @id @default(cuid())
  name   String
  state  DocState
  case   Case     @relation(fields: [caseId], references: [id])
  caseId String
}

model Payment {
  id            String        @id @default(cuid())
  amount        Int
  currency      String
  status        PaymentStatus
  description   String
  invoiceNumber String
  case          Case          @relation(fields: [caseId], references: [id])
  caseId        String
}

model TimelineEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  details   String
  case      Case     @relation(fields: [caseId], references: [id])
  caseId    String
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  body      String   @db.Text
  case      Case     @relation(fields: [caseId], references: [id])
  caseId    String
}

enum Role {
  CLIENT
  STAFF
  ADMIN
  LVJ_ADMIN
  LVJ_TEAM
  LVJ_MARKETING
  LAWYER_ADMIN
  LAWYER_ASSOCIATE
  LAWYER_ASSISTANT
}

enum PartnerType {
  REFERRAL_AGENCY
  RC_OPERATOR
  LEGAL_AID
  CO_COUNSEL
}

enum OutcomeResult {
  APPROVED
  DENIED
  WITHDRAWN
  PENDING
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

enum NotifChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum NotifStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum CaseStatus {
  new
  documents_pending
  in_review
  submitted
  approved
  denied
}

enum DocState {
  requested
  uploaded
  approved
  rejected
}

enum PaymentStatus {
  paid
  unpaid
  overdue
}

enum Direction {
  INCOMING
  OUTGOING
}

